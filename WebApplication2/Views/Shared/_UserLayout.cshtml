<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] eTutoring</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
</head>
<body>
    <header style="background: linear-gradient(to right, #f6d365, #fda085);">
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm" style="background: linear-gradient(to right, #f6d365, #fda085);">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index" style="color: #ff8c00;">
                    <img src="~/image/logo.png" alt="Logo" width="30" height="30" class="me-2">
                    eTutoring
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link text-white me-3" asp-controller="Home" asp-action="Index">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white me-3" asp-controller="Profile" asp-action="Index">Profile</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn rounded-pill px-4 py-2" style="background-color: #ff8c00; color: white;" asp-controller="Account" asp-action="Logout">
                                <i class="fas fa-sign-out-alt"></i> Logout
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <section class="bg-light text-center py-5">
        <div class="container">
            <h1 class="fw-bold">Welcome to Your Dashboard</h1>
            <p class="lead text-muted">Manage your profile, settings, and more with ease.</p>
        </div>
    </section>

    <div>
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="bg-dark text-white text-center py-4" style="background: linear-gradient(to right, #f6d365, #fda085);">
        <div class="container">
            <p>
                &copy; 2025 WebApplication. All rights reserved.
                <a class="text-white me-3" asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
            </p>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
