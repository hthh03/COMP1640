<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
</head>
<body>
    <header style="background: linear-gradient(to right, #f6d365, #fda085);">
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm"  style="background: linear-gradient(to right, #f6d365, #fda085);">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index" style="color: #ff8c00;">
                    <img src="~/image/logo.png" alt="Logo" width="30" height="30" class="me-2">
                    eTutoring
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link text-white me-3" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white me-3" asp-controller="Courses" asp-action="Index">Courses</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white me-3" asp-controller="Tutors" asp-action="Index">Tutors</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn rounded-pill px-4 py-2 " 
                               style="background-color: #ff8c00; color: white;" asp-controller="Account" asp-action="Login">
                                <i class="fas fa-sign-in-alt"></i> Login
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <section class="bg-light text-center py-5">
        <div class="container">
            <h1 class="fw-bold">Learn with Experts, Anytime, Anywhere</h1>
            <p class="lead text-muted">Join our eTutoring platform and explore the best online courses from top instructors.</p>
            <a class="btn btn-lg px-4" asp-controller="Account" asp-action="Register"
               style="background-color: #ff8c00; color: white; border-radius: 50px; padding: 12px 24px;">
                Get Started
            </a>
        </div>
    </section>

    <section class="bg-light text-center py-5">
        <div class="container">
            <h2 class="mb-4 fw-bold text-dark">Why Choose eTutoring?</h2>
            <div class="row d-flex justify-content-center gap-4">
                <div class="col-md-3">
                    <div class="p-4 bg-white shadow-sm text-center border rounded-3">
                        <i class="fas fa-chalkboard-teacher text-warning display-4"></i>
                        <h5 class="mt-3 fw-semibold text-dark">Experienced Tutors</h5>
                        <p class="text-muted">Learn from top instructors with real-world experience.</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="p-4 bg-white shadow-sm text-center border rounded-3">
                        <i class="fas fa-clock text-warning display-4"></i>
                        <h5 class="mt-3 fw-semibold text-dark">Flexible Schedule</h5>
                        <p class="text-muted">Access lessons anytime, anywhere that suits your schedule.</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="p-4 bg-white shadow-sm text-center border rounded-3">
                        <i class="fas fa-certificate text-warning display-4"></i>
                        <h5 class="mt-3 fw-semibold text-dark">Certified Courses</h5>
                        <p class="text-muted">Earn certificates to boost your career opportunities.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>


    <div >
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="bg-dark text-white text-center py-4" style="background: linear-gradient(to right, #f6d365, #fda085);">
        <div class="container">
            <p>&copy; 2025 eTutoring. All rights reserved.
                <a class="text-white me-3" asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
                <a class="text-white me-3" asp-controller="Home" asp-action="Contact">Contact Us</a>
            </p>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
